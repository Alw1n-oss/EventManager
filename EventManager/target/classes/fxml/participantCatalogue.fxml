<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="10.0" xmlns="http://javafx.com/javafx/11" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.hse.eventmanager.controller.ParticipantController">
   <children>
      <Label text="Каталог мероприятий" style="-fx-font-size: 18px;" />
      <TextField fx:id="filterField" maxWidth="500.0" promptText="Поиск..." />
      
      <HBox spacing="10.0" alignment="CENTER">
         <children>
            <!-- Таблица слева -->
            <TableView fx:id="catalogTable" prefHeight="250.0" prefWidth="360.0">
              <columns>
                <TableColumn fx:id="catTitleColumn" prefWidth="140.0" text="Название" />
                <TableColumn fx:id="catDateColumn" prefWidth="110.0" text="Дата" />
                <TableColumn fx:id="catVenueColumn" prefWidth="110.0" text="Место" />
              </columns>
            </TableView>
            
            <!-- Панель деталей справа -->
            <VBox spacing="8.0" prefWidth="220.0" style="-fx-padding: 10; -fx-border-color: #cccccc; -fx-border-radius: 5;">
               <children>
                  <Label text="Детали мероприятия" style="-fx-font-size: 14px; -fx-font-weight: bold;" />
                  <Label fx:id="detailTitle" text="Название: " wrapText="true" />
                  <Label fx:id="detailDate" text="Дата: " />
                  <Label fx:id="detailDesc" text="Описание: " wrapText="true" maxWidth="200.0" />
                  <Label fx:id="detailLimit" text="Осталось мест: " style="-fx-text-fill: #0066cc;" />
               </children>
            </VBox>
         </children>
      </HBox>
      
      <HBox alignment="CENTER" spacing="10.0">
         <children>
            <Button mnemonicParsing="false" onAction="#onRegisterClicked" text="Зарегистрироваться" />
            <Button mnemonicParsing="false" onAction="#handleBack" text="Назад" />
         </children>
      </HBox>
      <Label fx:id="errorLabel" textFill="RED" />
   </children>
   <padding>
      <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
   </padding>
</VBox>