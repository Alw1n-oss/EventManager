<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/11" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.hse.eventmanager.controller.OrganizerController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    
    <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Панель организатора" />
    
    <TableView fx:id="eventTable" prefHeight="200.0" prefWidth="600.0">
        <columns>
            <TableColumn fx:id="titleColumn" text="Название" prefWidth="200.0" />
            <TableColumn fx:id="dateColumn" text="Дата" prefWidth="150.0" />
            <TableColumn fx:id="venueColumn" text="Место" prefWidth="150.0" />
            <TableColumn fx:id="limitColumn" text="Лимит" prefWidth="100.0" />
        </columns>
    </TableView>
    
    <HBox spacing="10.0" alignment="CENTER">
        <TextField fx:id="titleField" promptText="Название" />
        <DatePicker fx:id="datePicker" />
        <ChoiceBox fx:id="venueChoiceBox" prefWidth="150.0" />
        <TextField fx:id="limitField" promptText="Лимит" prefWidth="80.0" />
    </HBox>
    
    <TextArea fx:id="descText" promptText="Описание" prefHeight="80.0" prefWidth="500.0" />
    
    <Label fx:id="errorLabel" textFill="RED" />
    
    <HBox spacing="10.0" alignment="CENTER">
        <Button text="Создать" onAction="#onCreateEvent" />
        <Button text="Изменить" onAction="#onUpdateEvent" />
        <Button text="Назад" onAction="#handleBack" />
    </HBox>
</VBox>